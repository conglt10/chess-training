{
  "name": "chess-opening-trainer-server",
  "version": "1.0.0",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc && node scripts/copy-assets.mjs && node scripts/build-explorer-index.mjs",
    "build:index": "node scripts/build-explorer-index.mjs",
    "start": "node dist/index.js",
    "download-tsv": "node scripts/download-tsv.mjs",
    "download-master-games": "node scripts/download-master-games.mjs",
    "download-legend-games": "node scripts/download-legend-games.mjs",
    "download-opening-games": "node scripts/download-opening-games.mjs"
  },
  "dependencies": {
    "chess.js": "^1.3.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "node-fetch": "^3.3.2",
    "stockfish": "^18.0.7",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.13",
    "fflate": "^0.8.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
